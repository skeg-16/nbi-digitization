{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:desktop": "node scripts/build-desktop.js"
  },
  "build": {
    "appId": "com.nbisystem.desktop",
    "productName": "NBI Digitization System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": ["**/*"]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "standalone/node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "../ocr-service/dist/ocr-service",
        "to": "ocr-service",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.0.0",
    "dotenv": "^17.4.2",
    "googleapis": "^173.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "fs-extra": "^11.3.5",
    "tailwindcss": "^4"
  }
}
